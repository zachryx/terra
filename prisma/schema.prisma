// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum UserRole {
  ADMIN
  ORGANIZER
  SPONSOR
  ATTENDEE
}

enum SsoProvider {
  GOOGLE
  FACEBOOK
  LOCAL
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String?
  name          String?
  avatar        String?
  role          UserRole    @default(ATTENDEE)
  provider      SsoProvider @default(LOCAL)
  providerId    String?
  isActive      Boolean     @default(true)
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sessions           Session[]
  verificationTokens VerificationToken[]
  securityLogs       SecurityLog[]
  promoCodeUsages    PromoCodeUsage[]
  events        Event[]
  orders        Order[]

  @@index([email])
  @@index([provider, providerId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  @@index([token])
  @@index([userId])
}

model Event {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  venue       String
  capacity    Int
  status      String   @default("DRAFT")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  tickets     Ticket[]
  promoCodes  PromoCode[]
}

model Ticket {
  id            String    @id @default(uuid())
  name          String
  description   String?
  ticketType    String    @default("GENERAL")
  price         Float
  quantity      Int
  sold          Int       @default(0)
  maxPerOrder   Int       @default(10)
  minPerOrder   Int       @default(1)
  saleStartDate DateTime?
  saleEndDate   DateTime?
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders       OrderItem[]

  @@index([eventId])
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  totalAmount  Float
  discountAmount Float     @default(0)
  finalAmount  Float
  status       OrderStatus @default(PENDING)
  paymentId    String?
  promoCodeId  String?
  promoCode    PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items        OrderItem[]
  promoCodeUsages PromoCodeUsage[]

  @@index([userId])
  @@index([status])
  @@index([promoCodeId])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  quantity  Int
  price     Float
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model SecurityLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      String
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  description     String?
  discountType    String    @default("PERCENTAGE")
  discountValue   Float
  minPurchaseAmount Float?
  maxUses         Int?
  usedCount       Int       @default(0)
  maxUsesPerUser  Int       @default(1)
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  eventId         String?
  event           Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usages          PromoCodeUsage[]
  orders          Order[]

  @@index([code])
  @@index([eventId])
}

model PromoCodeUsage {
  id            String     @id @default(uuid())
  promoCodeId   String
  promoCode     PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  orderId       String
  order         Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discountAmount Float
  createdAt     DateTime   @default(now())

  @@index([promoCodeId])
  @@index([userId])
}
